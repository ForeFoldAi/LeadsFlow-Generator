# ─────────────────────────────────────────────────────────────────────────────
# Lead Generation API — environment variables
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite — no extra setup needed):
DATABASE_URL=sqlite+aiosqlite:///./leads.db

# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/leads_db

# ── API keys ──────────────────────────────────────────────────────────────────
APOLLO_API_KEY=your_apollo_api_key_here
HUNTER_API_KEY=your_hunter_api_key_here
SNOV_CLIENT_ID=your_snov_client_id_here
SNOV_CLIENT_SECRET=your_snov_client_secret_here
ROCKETREACH_API_KEY=your_rocketreach_api_key_here

# ── Social media credentials (for linkedin/facebook/instagram/twitter scrapers)
LINKEDIN_EMAIL=your_linkedin_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password

FACEBOOK_EMAIL=your_facebook_email@gmail.com
FACEBOOK_PASSWORD=your_facebook_password

INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

TWITTER_USERNAME=your_twitter_email@gmail.com
TWITTER_PASSWORD=your_twitter_password

# ── CORS (comma-separated list of allowed origins) ───────────────────────────
# CORS_ORIGINS=["http://localhost:3000","https://yourfrontend.com"]
